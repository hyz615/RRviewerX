# Backend environment variables
APP_ENV=dev
SECRET_KEY=change-me
# 允许的前端来源，逗号分隔；默认包含 8080（本仓库前端静态服务端口）
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://localhost:3000
# 可选：使用正则匹配前端来源（与 ALLOWED_ORIGINS 同时生效）。
# 例：允许 example.com 与其所有子域：^https?://(.*\.)?example\.com$
ALLOWED_ORIGIN_REGEX=
RESEND_API_KEY= # re_xxx...
EMAIL_FROM="RRviewerno-reply@yourdomain.com"
# 前端站点基础地址（完整 URL），用于后端根路径重定向与邮件内链接拼接。
# 留空时将回落到 ALLOWED_ORIGINS 中的第一个。
FRONTEND_BASE=http://localhost:8080
# AI Providers
OPENAI_API_KEY= # sk-...
DEEPSEEK_API_KEY=
# openai|deepseek|mock
LLM_PROVIDER=openai
# e.g. gpt-4o-mini | deepseek-chat
LLM_MODEL=gpt-4o-mini
# 可选：自定义 OpenAI 兼容 API 基址（如 DeepSeek 网关）
LLM_BASE_URL=
# 可选：配置多个 OpenAI 兼容端点做轮询/故障切换。JSON 数组，每项支持
# name / provider / model / api_key / base_url，例如：
# LLM_API_CONFIGS=[{"name":"main-openai","provider":"openai","model":"gpt-4o-mini","api_key":"sk-..."},{"name":"backup-deepseek","provider":"deepseek","model":"deepseek-chat","api_key":"sk-...","base_url":"https://api.deepseek.com"}]
LLM_API_CONFIGS=

# 可选：视觉模型（VLM）配置，用于图片/扫描版 PDF 先做视觉摘要，再交给主 LLM。
VLM_PROVIDER=openai
VLM_MODEL=gpt-4o-mini
VLM_BASE_URL=
VLM_API_KEY=
# 可选：VLM 也支持多端点轮询，格式与 LLM_API_CONFIGS 相同。
VLM_API_CONFIGS=
# 单次最多发送多少张图片给 VLM
VLM_MAX_IMAGES=6
# 图片型 PDF 最多取多少页做视觉摘要
VLM_PDF_PAGE_LIMIT=4
# 视觉摘要写回文本管线时的最大字符数
VLM_SUMMARY_MAX_CHARS=3000

# OAuth (placeholders; integrate real client IDs/secrets in production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Meta (Facebook) OAuth
META_CLIENT_ID=
META_CLIENT_SECRET=

DATABASE_URL=sqlite:///./rrviewer.db

# 清理与长文本预处理
RETENTION_DAYS=7
CLEAN_INTERVAL_HOURS=6
MAX_INPUT_CHARS=16000
CONDENSE_TARGET_CHARS=6000

# Stripe（需在 Stripe 后台创建 price 并填写对应 ID）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# 如 price_12345...（不是金额）
STRIPE_PRICE_30=
STRIPE_PRICE_90=
STRIPE_PRICE_365=

# 可选：文本向量模型配置（嵌入）
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# 非 VIP 用户每月免费额度（默认 5）
FREE_MONTHLY_LIMIT=5

# Windows 下可指定 Tesseract 可执行文件路径（若未加入 PATH）
# 例如：C:\\Program Files\\Tesseract-OCR\\tesseract.exe
TESSERACT_CMD=
